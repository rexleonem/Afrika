AI_PUBLIC_URL="https://afrika-ai.techculture.live"
INGESTION_PUBLIC_URL="http://localhost:5100"
SERVER_ORIGIN="https://afrika.techculture.live"
WEB_ORIGIN="https://afrika.ng"
ADMIN_ORIGIN="https://admin.afrika.ng"
ALLOWED_ORIGINS="https://afrika.ng,https://www.afrika.ng,https://admin.afrika.ng"

# Auth
CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# AI providers
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"
GEMINI_MODEL="gemini-2.5-flash"

GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="llama-3.3-70b-versatile"

DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Media
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
