generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  name           String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  saves          Save[]
  plans          Plan[]
  preferences    UserPreference?
}

model Card {
  id              String   @id
  title           String
  locationName    String
  category        String
  kind            String
  tags            String[]
  summary         String
  whyItMatters    String
  imageUrl        String
  videoUrl        String?
  lat             Float
  lng             Float
  freshnessScore  Float
  trustScore      Float
  relevanceScore  Float
  decayRate       Float
  lastVerifiedAt  DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  saves           Save[]
  embeddings      Embedding[]
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
}

model Location {
  id        String   @id @default(cuid())
  name      String
  lat       Float
  lng       Float
  geoHash   String?
  createdAt DateTime @default(now())
}

model Plan {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  items     PlanItem[]
}

model PlanItem {
  id        String   @id @default(cuid())
  planId    String
  cardId    String?
  title     String
  note      String?
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model Trend {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  score     Float
  createdAt DateTime @default(now())
}

model Embedding {
  id        String   @id @default(cuid())
  cardId    String
  model     String
  vector    Unsupported("vector")
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  score     Float
  reason    String
  createdAt DateTime @default(now())
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  preferredCities String[]
  interests       String[]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
